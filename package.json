{
  "name": "temp_new_app",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:single": "vue-tsc -b && vite build --config vite.config.single.ts",
    "build:all": "npm run build && npm run build:single && node -e \"const fs=require('fs'); fs.copyFileSync('dist-single/index.html', 'dist/single.html'); fs.mkdirSync('dist/index', {recursive:true}); fs.copyFileSync('dist-single/index.html', 'dist/index/single.html')\"",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "element-plus": "^2.13.1",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-singlefile": "^2.3.2",
    "vue-tsc": "^3.1.4"
  }
}
